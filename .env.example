# Environment Variables Example for Root

NODE_ENV=development

# Database
POSTGRES_USER=fifa_admin
POSTGRES_PASSWORD=secret
POSTGRES_DB=fifa_command_center
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Authentication
JWT_SECRET=replace_me_with_a_secure_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers
OPENAI_API_KEY=sk-your_openai_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
GOOGLE_AI_API_KEY=AIzaSy_your_google_key
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o

# Backend Configuration
CORS_ORIGINS=["http://localhost:3000","http://localhost"]
LOG_LEVEL=INFO

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
NEXT_PUBLIC_APP_NAME="FIFA 2026 Command Center"

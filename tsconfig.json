{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@fifa/types": ["packages/types/src/index"],
      "@fifa/ui": ["packages/ui/src/index"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
